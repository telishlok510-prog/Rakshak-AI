# Copy this file to .env.local and add your key.
# The app works in DEMO MODE (heuristic detection) without a key,
# but AI-powered explanations require the Gemini API (free, no credit card).

# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model (defaults to gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite
